class Solution {
  public:
    bool isSubsetSum(vector<int>& arr, int sum) {
        int n = arr.size();
        vector<int> dp(sum+1,false);
        dp[0] = true;
        for(int i = 0;i<n;i++){
            for(int j = sum;arr[i]<=j;j--){
                dp[j] = dp[j-arr[i]] || dp[j];
            }
        }
        return dp[sum];
        
    }
};
