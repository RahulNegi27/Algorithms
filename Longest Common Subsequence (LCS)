#include <iostream>
#include <vector>
using namespace std;

int LCS(string X, string Y, int m, int n, vector<vector<int>>& dp)
{
    if (m == 0 || n == 0)
        return 0;

    if (dp[m][n] != -1)
        return dp[m][n];

    if (X[m - 1] == Y[n - 1])
        return dp[m][n] = 1 + LCS(X, Y, m - 1, n - 1, dp);

    return dp[m][n] = max(
        LCS(X, Y, m - 1, n, dp),
        LCS(X, Y, m, n - 1, dp)
    );
}

int main()
{
    string X, Y;

    cout << "Enter first string: ";
    cin >> X;

    cout << "Enter second string: ";
    cin >> Y;

    int m = X.length();
    int n = Y.length();

    vector<vector<int>> dp(m + 1, vector<int>(n + 1, -1));

    cout << "Length of LCS = "
         << LCS(X, Y, m, n, dp);

    return 0;
}
